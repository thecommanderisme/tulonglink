{
  "expo": {
    "name": "TulongLink",
    "slug": "tulonglink",
    "version": "1.0.0",
    "scheme": "tulonglink",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D9E75"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}